# Database Configuration
# Get your DATABASE_URL from Neon.tech or your PostgreSQL provider
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/property_maintenance

# Server Configuration
PORT=3001
NODE_ENV=development

# Production Deployment Notes (Render):
# - DATABASE_URL is automatically provided by Render's PostgreSQL service
# - PORT is automatically set by Render
# - NODE_ENV should be set to "production" in environment variables
